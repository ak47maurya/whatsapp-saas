<%
const isActive = (path) => currentPath?.startsWith(path) ? 'active' : '';
const hasFeature = (feature) => {
  if (!user) return false;
  if (user.role === 'super_admin') return true;
  const sub = user._subscription;
  if (!sub) return false;
  const feats = sub.features || sub.plan?.features || {};
  if (feats[feature] === -1) return true;
  if (feats[feature] === true) return true;
  if (typeof feats[feature] === 'number' && feats[feature] > 0) return true;
  return false;
};
%>
<div class="sidebar">
  <div class="sidebar-header">
    <a href="/dashboard" class="sidebar-brand">
      <svg width="22" height="22" viewBox="0 0 100 100" fill="none" style="vertical-align:middle;margin-right:6px">
        <rect x="10" y="10" width="80" height="80" rx="18" fill="url(#ag2)" stroke="#00d4ff" stroke-width="3"/>
        <text x="50" y="66" text-anchor="middle" fill="#00d4ff" font-size="48" font-weight="bold" font-family="sans-serif">A</text>
        <defs><linearGradient id="ag2" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="#0a0a2e"/><stop offset="100%" stop-color="#001a33"/></linearGradient></defs>
      </svg>
      <span style="color:#00d4ff;font-weight:700">akautomation</span>
    </a>
  </div>
  <ul class="sidebar-nav">
    <li class="nav-item">
      <a href="/dashboard" class="nav-link <%= isActive('/dashboard') %>">
        <i class="fas fa-tachometer-alt"></i> <span>Dashboard</span>
      </a>
    </li>

    <% if (isAdmin) { %>
    <li class="nav-section">Administration</li>
    <li class="nav-item">
      <a href="/admin/dashboard" class="nav-link <%= isActive('/admin/dashboard') %>">
        <i class="fas fa-chart-bar"></i> <span>Admin Dashboard</span>
      </a>
    </li>
    <li class="nav-item">
      <a href="/users" class="nav-link <%= isActive('/users') %>">
        <i class="fas fa-users-cog"></i> <span>Users</span>
      </a>
    </li>
    <li class="nav-item">
      <a href="/plans" class="nav-link <%= isActive('/plans') %>">
        <i class="fas fa-box"></i> <span>Plans</span>
      </a>
    </li>
    <li class="nav-item">
      <a href="/admin/subscriptions" class="nav-link <%= isActive('/admin-subscriptions') %>">
        <i class="fas fa-credit-card"></i> <span>Subscriptions</span>
      </a>
    </li>
    <li class="nav-item">
      <a href="/admin/invoices" class="nav-link <%= isActive('/admin/invoices') %>">
        <i class="fas fa-file-invoice-dollar"></i> <span>Invoices</span>
      </a>
    </li>
    <li class="nav-item">
      <a href="/admin/activity" class="nav-link <%= isActive('/admin/activity') %>">
        <i class="fas fa-history"></i> <span>Activity Log</span>
      </a>
    </li>
    <li class="nav-item">
      <a href="/admin/queue" class="nav-link <%= isActive('/admin/queue') %>">
        <i class="fas fa-tasks"></i> <span>Queue Monitor</span>
      </a>
    </li>
    <% if (user?.role === 'super_admin') { %>
    <li class="nav-item">
      <a href="/admin/settings" class="nav-link <%= isActive('/admin/settings') %>">
        <i class="fas fa-cog"></i> <span>Settings</span>
      </a>
    </li>
    <% } %>
    <% } %>

    <li class="nav-section">WhatsApp</li>
    <li class="nav-item">
      <a href="/instances" class="nav-link <%= isActive('/instances') %>">
        <i class="fab fa-whatsapp"></i> <span>Instances</span>
      </a>
    </li>
    <li class="nav-item">
      <a href="/messages" class="nav-link <%= isActive('/messages') %>">
        <i class="fas fa-envelope"></i> <span>Messages</span>
      </a>
    </li>
    <% if (hasFeature('bulkMessaging')) { %>
    <li class="nav-item">
      <a href="/messages/bulk-list" class="nav-link <%= isActive('/messages/bulk') %>">
        <i class="fas fa-users"></i> <span>Bulk Messages</span>
      </a>
    </li>
    <% } %>
    <% if (hasFeature('chatbot')) { %>
    <li class="nav-item">
      <a href="/chatbot" class="nav-link <%= isActive('/chatbot') %>">
        <i class="fas fa-robot"></i> <span>Chatbot</span>
      </a>
    </li>
    <% } %>
    <% if (hasFeature('dynamicMessaging')) { %>
    <li class="nav-item">
      <a href="/dynamic-messaging" class="nav-link <%= isActive('/dynamic-messaging') %>">
        <i class="fas fa-tag"></i> <span>Dynamic Messaging</span>
      </a>
    </li>
    <% } %>
    <li class="nav-item">
      <a href="/inbox" class="nav-link <%= isActive('/inbox') %>">
        <i class="fas fa-inbox"></i> <span>Inbox</span>
      </a>
    </li>
    <% if (hasFeature('mediaMessaging')) { %>
    <li class="nav-item">
      <a href="/media-gallery" class="nav-link <%= isActive('/media-gallery') %>">
        <i class="fas fa-folder-open"></i> <span>Media Gallery</span>
      </a>
    </li>
    <% } %>
    <% if (hasFeature('campaignAccess')) { %>
    <li class="nav-item">
      <a href="/campaigns" class="nav-link <%= isActive('/campaigns') %>">
        <i class="fas fa-bullhorn"></i> <span>Campaigns</span>
      </a>
    </li>
    <% } %>
    
    <li class="nav-section">Contacts</li>
    <li class="nav-item">
      <a href="/contacts" class="nav-link <%= isActive('/contacts') %>">
        <i class="fas fa-address-book"></i> <span>Contacts</span>
      </a>
    </li>
    <li class="nav-item">
      <a href="/groups" class="nav-link <%= isActive('/groups') %>">
        <i class="fas fa-users"></i> <span>Groups</span>
      </a>
    </li>

    <% if (hasFeature('webhookAccess')) { %>
    <li class="nav-section">Integrations</li>
    <li class="nav-item">
      <a href="/webhooks" class="nav-link <%= isActive('/webhooks') %>">
        <i class="fas fa-webhook"></i> <span>Webhooks</span>
      </a>
    </li>
    <% } %>

    <% if (hasFeature('apiAccess')) { %>
    <li class="nav-item">
      <a href="/api-keys" class="nav-link <%= isActive('/api-keys') %>">
        <i class="fas fa-key"></i> <span>API Keys</span>
      </a>
    </li>
    <% } %>
    <li class="nav-item">
      <a href="/api-docs" class="nav-link <%= isActive('/api-docs') %>">
        <i class="fas fa-book"></i> <span>API Docs</span>
      </a>
    </li>

    <li class="nav-section">Account</li>
    <li class="nav-item">
      <a href="/subscriptions" class="nav-link <%= isActive('/subscriptions') %>">
        <i class="fas fa-credit-card"></i> <span>Subscriptions</span>
      </a>
    </li>
    <li class="nav-item">
      <a href="/invoices" class="nav-link <%= isActive('/invoices') %>">
        <i class="fas fa-file-invoice"></i> <span>Invoices</span>
      </a>
    </li>
    <li class="nav-item">
      <a href="/notifications" class="nav-link <%= isActive('/notifications') %>">
        <i class="fas fa-bell"></i> <span>Notifications</span>
      </a>
    </li>
  </ul>
</div>
