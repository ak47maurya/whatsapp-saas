<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>
<div class="main-content">
  <%- include('../partials/navbar') %>
  <div class="content p-7 m-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h4 class="mb-0">Dashboard</h4>
      <% if (subscription) { %>
        <span class="badge bg-<%= subscription.status === 'active' ? 'success' : 'warning' %> fs-6">
          <%= subscription.plan?.name || 'Free' %> Plan
        </span>
      <% } else { %>
        <a href="/plans" class="btn btn-success btn-sm">Choose a Plan</a>
      <% } %>
    </div>

    <div class="row g-3 mb-4">
      <div class="col-md-3">
        <div class="card border-0 shadow-sm">
          <div class="card-body">
            <div class="d-flex justify-content-between">
              <div><h6 class="card-subtitle text-muted">Instances</h6><h3 class="mb-0"><%= stats.connectedInstances %>/<%= stats.totalInstances %></h3></div>
              <div class="bg-success bg-opacity-10 p-3 rounded"><i class="fab fa-whatsapp text-success fs-4"></i></div>
            </div>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card border-0 shadow-sm">
          <div class="card-body">
            <div class="d-flex justify-content-between">
              <div><h6 class="card-subtitle text-muted">Today's Messages</h6><h3 class="mb-0"><%= stats.todayMessages %></h3></div>
              <div class="bg-info bg-opacity-10 p-3 rounded"><i class="fas fa-envelope text-info fs-4"></i></div>
            </div>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card border-0 shadow-sm">
          <div class="card-body">
            <div class="d-flex justify-content-between">
              <div><h6 class="card-subtitle text-muted">Monthly Usage</h6><h3 class="mb-0"><%= stats.monthlyMessages %>/<%= monthlyLimit %></h3></div>
              <div class="bg-warning bg-opacity-10 p-3 rounded"><i class="fas fa-chart-line text-warning fs-4"></i></div>
            </div>
            <div class="progress mt-2" style="height:4px"><div class="progress-bar" style="width:<%= Math.min(100, (stats.monthlyMessages/monthlyLimit)*100) %>%"></div></div>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card border-0 shadow-sm">
          <div class="card-body">
            <div class="d-flex justify-content-between">
              <div><h6 class="card-subtitle text-muted">Campaigns</h6><h3 class="mb-0"><%= stats.activeCampaigns %></h3></div>
              <div class="bg-primary bg-opacity-10 p-3 rounded"><i class="fas fa-bullhorn text-primary fs-4"></i></div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="row g-3">
      <div class="col-md-8">
        <div class="card border-0 shadow-sm">
          <div class="card-header bg-white"><h5 class="mb-0">My Instances</h5></div>
          <div class="card-body">
            <% if (instances && instances.length > 0) { %>
              <div class="table-responsive">
                <table class="table table-hover">
                  <thead><tr><th>Name</th><th>Phone</th><th>Status</th><th>Last Connected</th><th>Action</th></tr></thead>
                  <tbody>
                    <% instances.forEach(inst => { %>
                      <tr>
                        <td><%= inst.name %></td>
                        <td><%= inst.phone || '—' %></td>
                        <td><span class="badge bg-<%= inst.status === 'connected' ? 'success' : inst.status === 'qr_ready' ? 'info' : 'secondary' %>"><%= inst.status %></span></td>
                        <td><%= inst.lastConnected ? new Date(inst.lastConnected).toLocaleString() : '—' %></td>
                        <td><a href="/instances" class="btn btn-sm btn-outline-primary">Manage</a></td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            <% } else { %>
              <div class="text-center py-4">
                <p class="text-muted">No instances yet. Create your first WhatsApp instance.</p>
                <a href="/instances" class="btn btn-success">Create Instance</a>
              </div>
            <% } %>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card border-0 shadow-sm">
          <div class="card-header bg-white"><h5 class="mb-0">Quick Actions</h5></div>
          <div class="card-body">
            <div class="d-grid gap-2">
              <a href="/instances" class="btn btn-outline-success text-start"><i class="fab fa-whatsapp me-2"></i>New Instance</a>
              <a href="/messages" class="btn btn-outline-primary text-start"><i class="fas fa-paper-plane me-2"></i>Send Message</a>
              <a href="/campaigns" class="btn btn-outline-warning text-start"><i class="fas fa-bullhorn me-2"></i>New Campaign</a>
              <a href="/contacts" class="btn btn-outline-info text-start"><i class="fas fa-address-book me-2"></i>Import Contacts</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <%- include('../partials/footer') %>
</div>
<%- include('../partials/footer') %>
