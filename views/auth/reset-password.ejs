<%- include('../partials/header') %>
<div class="auth-wrapper"><div class="auth-card">
  <div class="text-center mb-4"><i class="fab fa-whatsapp text-success" style="font-size:3rem"></i><h3>Reset Password</h3></div>
  <% if (typeof error !== 'undefined' && error) { %><div class="alert alert-danger"><%= error %></div><% } %>
  <form method="POST" action="/auth/reset-password/<%= token %>">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <div class="mb-3"><label class="form-label">New Password</label><input type="password" name="password" class="form-control" minlength="8" required></div>
    <div class="mb-3"><label class="form-label">Confirm Password</label><input type="password" name="confirmPassword" class="form-control" minlength="8" required></div>
    <button type="submit" class="btn btn-success w-100">Reset Password</button>
  </form>
</div></div>
<style>.auth-wrapper{min-height:100vh;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,#667eea 0%,#764ba2 100%)}.auth-card{background:white;padding:2.5rem;border-radius:16px;width:100%;max-width:420px;box-shadow:0 20px 60px rgba(0,0,0,0.3)}</style>
</body></html>
