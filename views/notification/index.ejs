<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>
<div class="main-content">
  <%- include('../partials/navbar') %>
  <div class="content p-7 m-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h4 class="mb-0">Notifications</h4>
      <div>
        <button onclick="markAllRead()" class="btn btn-outline-primary btn-sm"><i class="fas fa-check-double"></i> Mark All Read</button>
      </div>
    </div>
    <div class="card border-0 shadow-sm">
      <div class="card-body">
        <% if (notifications && notifications.length > 0) { %>
          <div class="list-group">
            <% notifications.forEach(n => { %>
              <div class="list-group-item list-group-item-action d-flex justify-content-between align-items-start <%= !n.isRead ? 'list-group-item-primary' : '' %>">
                <div class="ms-2 me-auto">
                  <div class="fw-bold"><%= n.title %></div>
                  <p class="mb-0"><%= n.message %></p>
                  <small class="text-muted"><%= new Date(n.createdAt).toLocaleString() %></small>
                </div>
                <div>
                  <% if (!n.isRead) { %>
                    <button onclick="markRead('<%= n._id %>')" class="btn btn-sm btn-outline-success me-1"><i class="fas fa-check"></i></button>
                  <% } %>
                  <button onclick="deleteNotif('<%= n._id %>')" class="btn btn-sm btn-outline-danger"><i class="fas fa-times"></i></button>
                </div>
              </div>
            <% }) %>
          </div>
        <% } else { %>
          <div class="text-center py-4"><i class="fas fa-bell text-muted" style="font-size:3rem"></i><p class="mt-2 text-muted">No notifications</p></div>
        <% } %>
      </div>
    </div>
  </div>
  <%- include('../partials/footer') %>
</div>
<script>
function markRead(id) { api('/notifications/'+id+'/read',{method:'POST'}).then(r=>r.json()).then(d=>{if(d.success)location.reload();else Swal.fire('Error',d.message,'error');}); }
function markAllRead() { api('/notifications/read-all',{method:'POST'}).then(r=>r.json()).then(d=>{if(d.success)location.reload();else Swal.fire('Error',d.message,'error');}); }
function deleteNotif(id) { api('/notifications/'+id,{method:'DELETE'}).then(r=>r.json()).then(d=>{if(d.success)location.reload();else Swal.fire('Error',d.message,'error');}); }
</script>
