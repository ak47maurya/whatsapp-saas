<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>
<div class="main-content">
  <%- include('../partials/navbar') %>
  <div class="content p-7 m-4" style="max-width:600px">
    <div class="card border-0 shadow-sm">
      <div class="card-body">
        <h4 class="mb-3">New WhatsApp Instance</h4>
        <form method="POST" action="/instances">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <div class="mb-3">
            <label class="form-label">Instance Name</label>
            <input name="name" class="form-control" placeholder="e.g. My WhatsApp" required autofocus>
          </div>
          <button type="submit" class="btn btn-success"><i class="fas fa-plus"></i> Create Instance</button>
          <a href="/instances" class="btn btn-outline-secondary ms-2">Cancel</a>
        </form>
      </div>
    </div>
  </div>
  <%- include('../partials/footer') %>
</div>