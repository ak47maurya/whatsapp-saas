<%- include('../../partials/header') %>
<%- include('../../partials/sidebar') %>
<div class="main-content">
  <%- include('../../partials/navbar') %>
  <div class="content p-7 m-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h4 class="mb-0">System Settings</h4>
      <button class="btn btn-outline-primary" onclick="testEmail()"><i class="fas fa-envelope"></i> Send Test Email</button>
    </div>
    <div class="card border-0 shadow-sm">
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover mb-0">
            <thead class="table-light">
              <tr><th>Key</th><th>Value</th><th>Group</th><th>Description</th><th>Action</th></tr>
            </thead>
            <tbody>
              <% (settings || []).forEach(s => { %>
                <tr>
                  <td><code><%= s.key %></code></td>
                  <td id="val-<%= s._id %>">
                    <% if (s.type === 'boolean') { %>
                      <span class="badge bg-<%= s.value ? 'success' : 'secondary' %>"><%= s.value %></span>
                    <% } else { %>
                      <%= typeof s.value === 'object' ? JSON.stringify(s.value) : s.value %>
                    <% } %>
                  </td>
                  <td><span class="badge bg-secondary"><%= s.group %></span></td>
                  <td class="text-muted small"><%= s.description %></td>
                  <td><button class="btn btn-sm btn-primary" onclick="editSetting('<%= s._id %>', '<%= s.key %>', '<%= s.type %>', '<%= typeof s.value === 'string' ? s.value.replace(/'/g, "\\'") : s.value %>')"><i class="fas fa-edit"></i></button></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
  <%- include('../../partials/footer') %>
</div>

<script>
function testEmail() {
  Swal.fire({ title: 'Sending...', text: 'Please wait', allowOutsideClick: false, didOpen: () => Swal.showLoading() });
  fetch('/admin/settings/test-email', { method: 'POST', headers:{'x-csrf-token':csrfToken,'Accept':'application/json'} })
    .then(r => r.json()).then(d => {
      if (d.success) Swal.fire('Sent!','Check your inbox','success');
      else Swal.fire('Error',d.message,'error');
    }).catch(e => Swal.fire('Error',e.message,'error'));
}

function editSetting(id, key, type, currentVal) {
  let input;
  if (type === 'boolean') {
    input = `<select id="sv" class="form-select"><option value="true" ${currentVal === 'true' ? 'selected' : ''}>True</option><option value="false" ${currentVal !== 'true' ? 'selected' : ''}>False</option></select>`;
  } else if (type === 'number') {
    input = `<input id="sv" type="number" class="form-control" value="${currentVal}">`;
  } else {
    input = `<input id="sv" class="form-control" value="${currentVal}">`;
  }
  Swal.fire({
    title: 'Edit: ' + key,
    html: input,
    showCancelButton: true,
    confirmButtonText: 'Save',
    preConfirm: () => {
      const val = document.getElementById('sv').value;
      return fetch('/admin/settings', {
        method: 'PUT',
        headers: { 'x-csrf-token':csrfToken, 'Content-Type': 'application/json', 'Accept':'application/json' },
        body: JSON.stringify({ key, value: type === 'boolean' ? val === 'true' : type === 'number' ? parseFloat(val) : val })
      }).then(r => r.json()).then(d => {
        if (!d.success) { Swal.showValidationMessage(d.message); return false; }
        return d;
      });
    }
  }).then(r => { if (r.isConfirmed && r.value?.success) { Swal.fire('Saved','','success').then(()=>location.reload()); } });
}
</script>