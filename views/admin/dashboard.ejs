<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>
<div class="main-content">
  <%- include('../partials/navbar') %>
  <div class="content p-7 m-4">
    <h4 class="mb-4">Admin Dashboard</h4>
    <div class="row g-3 mb-4">
      <div class="col-md-3"><div class="card border-0 shadow-sm"><div class="card-body"><h6 class="text-muted">Total Users</h6><h2><%= stats.totalUsers %></h2></div></div></div>
      <div class="col-md-3"><div class="card border-0 shadow-sm"><div class="card-body"><h6 class="text-muted">Active Users</h6><h2 class="text-success"><%= stats.activeUsers %></h2></div></div></div>
      <div class="col-md-3"><div class="card border-0 shadow-sm"><div class="card-body"><h6 class="text-muted">Instances</h6><h2><%= stats.connectedInstances %>/<%= stats.totalInstances %></h2></div></div></div>
      <div class="col-md-3"><div class="card border-0 shadow-sm"><div class="card-body"><h6 class="text-muted">Revenue</h6><h2 class="text-primary">₹<%= stats.totalRevenue.toLocaleString() %></h2></div></div></div>
    </div>
    <div class="row g-3">
      <div class="col-md-6">
        <div class="card border-0 shadow-sm">
          <div class="card-header bg-white"><h5 class="mb-0">Recent Users</h5></div>
          <div class="card-body">
            <table class="table table-sm">
              <thead><tr><th>Name</th><th>Email</th><th>Status</th><th>Joined</th></tr></thead>
              <tbody>
                <% (recentUsers || []).forEach(u => { %>
                  <tr><td><%= u.name %></td><td><%= u.email %></td><td><span class="badge bg-<%= u.status === 'active' ? 'success' : 'secondary' %>"><%= u.status %></span></td><td><%= new Date(u.createdAt).toLocaleDateString() %></td></tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
      <div class="col-md-6">
        <div class="card border-0 shadow-sm">
          <div class="card-header bg-white"><h5 class="mb-0">System Stats</h5></div>
          <div class="card-body">
            <div class="mb-2"><strong>Active Connections:</strong> <%= activeConnections || 0 %></div>
            <div class="mb-2"><strong>Total Messages:</strong> <%= stats.totalMessages?.toLocaleString() %></div>
            <div class="mb-2"><strong>Active Campaigns:</strong> <%= stats.totalCampaigns %></div>
            <div class="mb-2"><strong>Queue Count:</strong> <%= queueMetrics?.length || 0 %> queues</div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <%- include('../partials/footer') %>
</div>
