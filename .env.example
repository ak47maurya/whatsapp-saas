# Server
NODE_ENV=development
PORT=3002
HOST=0.0.0.0

# MongoDB
MONGODB_URI=mongodb://localhost:27017/whatsapp-saas

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Session - CHANGE THESE SECRETS IN PRODUCTION
SESSION_SECRET=change-this-to-a-random-secret-key
SESSION_MAX_AGE=86400000

# JWT - CHANGE THESE SECRETS IN PRODUCTION
JWT_SECRET=change-this-to-another-random-secret-key
JWT_EXPIRES_IN=7d

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM="WhatsApp SaaS"

# App
APP_NAME=WhatsApp SaaS
APP_URL=http://localhost:3002
APP_LOGO=/images/logo.png

# Upload
UPLOAD_DIR=public/uploads
MAX_FILE_SIZE=52428800

# Queue
QUEUE_PREFIX=wa-saas
QUEUE_CONCURRENCY=5

# Rate Limit
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=500

# Baileys WhatsApp
BAILEYS_AUTH_DIR=auth_info
BAILEYS_SYNC_FULL_HISTORY=false
BAILEYS_MARK_READ_ON_SEND=false

# Logging
LOG_LEVEL=info
LOG_DIR=logs

# Trial
TRIAL_DAYS=7
TRIAL_MESSAGE_LIMIT=50

# Default Admin (seeded on first run)
ADMIN_EMAIL=anoopdiploma@gmail.com
ADMIN_PASSWORD=Admin@123456
ADMIN_NAME=Super Admin
